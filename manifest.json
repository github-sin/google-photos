{
  "manifest_version": 3,
  "name": "Google フォト一括削除",
  "version": "1.0.0",
  "description": "Googleフォトの写真を一括で削除します",
  "permissions": [
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://photos.google.com/*",
    "https://api.gumroad.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://photos.google.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
